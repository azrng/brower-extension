</style>

@code {
    private BossJobSkillAnalyzer.Models.PluginConfig Config = new();
    private BossJobSkillAnalyzer.Models.TaskProgress? Progress = new();
    private bool IsExpanded = true;
    private bool ShowApiKey = false;
    private bool IsTaskRunning = false;
    private string ErrorMessage = string.Empty;
    private string SuccessMessage = string.Empty;
    private System.Threading.CancellationTokenSource? _cancellationTokenSource;

    protected override async Task OnInitializedAsync()
    {
        await LoadConfigAsync();
    }

    private async Task LoadConfigAsync()
    {
        Config = await ConfigStorage.LoadConfigAsync();
    }

    private async Task SaveConfig()
    {
        await ConfigStorage.SaveConfigAsync(Config);
        SuccessMessage = "配置已保存";
        await Task.Delay(2000);
        SuccessMessage = string.Empty;
    }

    private void ToggleApiKeyVisibility()
    {
        ShowApiKey = !ShowApiKey;
    }

    private void ToggleSidebar()
    {
        IsExpanded = !IsExpanded;
    }

    private void CloseSidebar()
    {
        IsExpanded = false;
    }

    private string GetSidebarClass()
    {
        return IsExpanded ? "" : "collapsed";
    }

    private string GetStatusClass()
    {
        if (Progress == null) return "status-not-started";

        return Progress.Status switch
        {
            AnalysisStatus.NotStarted => "status-not-started",
            AnalysisStatus.Running => "status-running",
            AnalysisStatus.Completed => "status-completed",
            AnalysisStatus.Stopped => "status-stopped",
            AnalysisStatus.Failed => "status-failed",
            _ => "status-not-started"
        };
    }

    private string GetStatusText()
    {
        if (Progress == null) return "未开始";

        return Progress.Status switch
        {
            AnalysisStatus.NotStarted => "未开始",
            AnalysisStatus.Running => "运行中",
            AnalysisStatus.Completed => "已完成",
            AnalysisStatus.Stopped => "已停止",
            AnalysisStatus.Failed => "失败",
            _ => "未知"
        };
    }

    private string GetProgressPercent()
    {
        if (Progress == null || Progress.TotalJobs == 0) return "0";
        return ((double)Progress.ProcessedJobs / Progress.TotalJobs * 100).ToString("F0");
    }

    private async Task StartTask()
    {
        if (!Config.IsValid())
        {
            ErrorMessage = "请先填写完整的配置信息";
            return;
        }

        _cancellationTokenSource = new System.Threading.CancellationTokenSource();
        IsTaskRunning = true;
        ErrorMessage = string.Empty;

        Progress = new BossJobSkillAnalyzer.Models.TaskProgress
        {
            Status = AnalysisStatus.Running,
            Stage = TaskStage.ReadingJobList,
            CurrentPage = 0,
            TotalPages = Config.MaxPages,
            ProcessedJobs = 0,
            TotalJobs = 0
        };

        await InvokeAsync(StateHasChanged);

        try
        {
            await ExecuteTaskAsync(_cancellationTokenSource.Token);
        }
        catch (Exception ex)
        {
            Progress.Status = AnalysisStatus.Failed;
            ErrorMessage = $"任务失败: {ex.Message}";
        }
        finally
        {
            IsTaskRunning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task StopTask()
    {
        _cancellationTokenSource?.Cancel();
        if (Progress != null)
        {
            Progress.Status = AnalysisStatus.Stopped;
        }
        IsTaskRunning = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ExecuteTaskAsync(CancellationToken cancellationToken)
    {
        var allJobs = new List<BossJobSkillAnalyzer.Models.JobInfo>();
        var individualResults = new List<BossJobSkillAnalyzer.Models.SkillAnalysisResult>();

        // 收集所有职位信息
        for (int page = 1; page <= Config.MaxPages && !cancellationToken.IsCancellationRequested; page++)
        {
            Progress!.CurrentPage = page;
            Progress.Stage = TaskStage.ReadingJobList;
            Progress.LastMessage = $"正在读取第 {page} 页职位列表";
            await InvokeAsync(StateHasChanged);

            // 调用 Content Script 提取职位列表
            var jobs = await ExtractJobListFromPage();
            if (jobs.Count == 0)
            {
                Progress.LastMessage = "第 " + page + " 页未找到职位，任务结束";
                break;
            }

            allJobs.AddRange(jobs);
            Progress.TotalJobs = allJobs.Count;
            await InvokeAsync(StateHasChanged);

            // 如果不是最后一页，翻页
            if (page < Config.MaxPages)
            {
                await Task.Delay(Config.ProcessInterval, cancellationToken);
                await GoToNextPage();
            }
        }

        // 处理每个职位
        for (int i = 0; i < allJobs.Count && !cancellationToken.IsCancellationRequested; i++)
        {
            var job = allJobs[i];
            Progress!.ProcessedJobs = i;
            Progress.Stage = TaskStage.OpeningJobDetail;
            Progress.LastMessage = $"正在处理职位 {i + 1}/{allJobs.Count}: {job.Title}";
            await InvokeAsync(StateHasChanged);

            try
            {
                // 打开详情页
                var tabId = await OpenDetailTab(job.Url);
                if (tabId == null)
                {
                    job.ErrorMessage = "无法打开详情页";
                    continue;
                }

                await Task.Delay(Config.ProcessInterval, cancellationToken);

                // 提取详情
                Progress.Stage = TaskStage.ExtractingJobContent;
                await InvokeAsync(StateHasChanged);

                var detail = await ExtractJobDetail();
                job.Experience = detail.Experience;
                job.Description = detail.Description;
                job.IsExtracted = true;

                // AI 分析
                Progress.Stage = TaskStage.CallingAI;
                await InvokeAsync(StateHasChanged);

                var result = await OpenAIService.AnalyzeSingleJobAsync(job, Config);
                job.AnalysisCompleted = true;
                individualResults.Add(result);

                // 关闭标签页
                await CloseTab(tabId.Value);

                await Task.Delay(Config.ProcessInterval, cancellationToken);
            }
            catch (Exception ex)
            {
                job.ErrorMessage = ex.Message;
                // 单个职位失败，继续处理下一个
            }
        }

        // 汇总分析
        if (individualResults.Any() && !cancellationToken.IsCancellationRequested)
        {
            Progress!.Stage = TaskStage.AggregatingResults;
            Progress.LastMessage = "正在汇总分析结果";
            await InvokeAsync(StateHasChanged);

            var finalResult = await OpenAIService.AnalyzeAggregatedResultsAsync(individualResults, Config);
            Progress.Result = finalResult;
        }

        Progress!.Status = AnalysisStatus.Completed;
        Progress.Stage = TaskStage.Completed;
        Progress.ProcessedJobs = allJobs.Count;
        Progress.LastMessage = "任务已完成";
        await InvokeAsync(StateHasChanged);
    }

    private async Task<List<BossJobSkillAnalyzer.Models.JobInfo>> ExtractJobListFromPage()
    {
        // 向 Content Script 发送消息提取职位列表
        var response = await JSRuntime.InvokeAsync<object>("chrome.runtime.sendMessage", new
        {
            action = "extractJobList"
        });

        // 这里需要解析响应，暂时返回模拟数据
        return new List<BossJobSkillAnalyzer.Models.JobInfo>();
    }

    private async Task<int?> OpenDetailTab(string url)
    {
        try
        {
            var response = await JSRuntime.InvokeAsync<object>("chrome.runtime.sendMessage", new
            {
                action = "openDetailTab",
                data = new { url = url }
            });

            // 解析响应获取 tabId
            return null; // 暂时返回 null
        }
        catch
        {
            return null;
        }
    }

    private async Task<BossJobSkillAnalyzer.Models.JobInfo> ExtractJobDetail()
    {
        try
        {
            var response = await JSRuntime.InvokeAsync<object>("chrome.runtime.sendMessage", new
            {
                action = "extractJobDetail"
            });

            // 解析响应
            return new BossJobSkillAnalyzer.Models.JobInfo();
        }
        catch
        {
            return new BossJobSkillAnalyzer.Models.JobInfo();
        }
    }

    private async Task CloseTab(int tabId)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("chrome.runtime.sendMessage", new
            {
                action = "closeTab",
                data = new { tabId = tabId }
            });
        }
        catch { }
    }

    private async Task GoToNextPage()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("chrome.runtime.sendMessage", new
            {
                action = "goToNextPage"
            });
        }
        catch { }
    }

    private async Task ExportJson()
    {
        if (Progress?.Result == null) return;

        var json = System.Text.Json.JsonSerializer.Serialize(Progress.Result, new System.Text.Json.JsonSerializerOptions
        {
            WriteIndented = true
        });

        // 创建下载
        await JSRuntime.InvokeVoidAsync("downloadJson", json, $"boss_skill_analysis_{DateTime.Now:yyyyMMdd_HHmmss}.json");

        SuccessMessage = "JSON 导出成功";
        await Task.Delay(2000);
        SuccessMessage = string.Empty;
    }

    public void Dispose()
    {
        _cancellationTokenSource?.Cancel();
        _cancellationTokenSource?.Dispose();
    }
}
