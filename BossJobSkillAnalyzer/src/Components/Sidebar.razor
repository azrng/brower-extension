@inject IJSRuntime JSRuntime
@inject BossJobSkillAnalyzer.Services.ConfigStorageService ConfigStorage
@inject BossJobSkillAnalyzer.Services.OpenAIService OpenAIService
@implements IDisposable

<div class="sidebar-container @GetSidebarClass()">
    <!-- 顶部标题区 -->
    <div class="sidebar-header">
        <div class="header-title">
            <h3>职位技能分析</h3>
            @if (Progress != null)
            {
                <span class="status-badge @GetStatusClass()">@GetStatusText()</span>
            }
        </div>
        <div class="header-actions">
            <button class="icon-btn" @onclick="ToggleSidebar" title="收起/展开">
                <span>@(IsExpanded ? "◀" : "▶")</span>
            </button>
            <button class="icon-btn" @onclick="CloseSidebar" title="关闭">
                <span>✕</span>
            </button>
        </div>
    </div>

    @if (IsExpanded)
    {
        <!-- 任务控制区 -->
        <div class="sidebar-section">
            <div class="button-group">
                <button class="primary-btn" disabled="@IsTaskRunning" @onclick="StartTask">
                    开始识别
                </button>
                <button class="secondary-btn" disabled="@(Progress?.Status == AnalysisStatus.NotStarted || Progress?.Status == AnalysisStatus.Completed)" @onclick="StopTask">
                    停止任务
                </button>
            </div>
        </div>

        <!-- 参数配置区 -->
        <div class="sidebar-section">
            <h4>参数配置</h4>
            <EditForm Model="@Config" OnValidSubmit="SaveConfig">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>API Base URL *</label>
                    <InputText @bind-Value="Config.ApiBaseUrl" class="form-control"
                               placeholder="https://api.openai.com/v1" />
                    <ValidationMessage For="() => Config.ApiBaseUrl" />
                </div>

                <div class="form-group">
                    <label>API Key *</label>
                    <div class="input-group">
                        <InputText type="@(!ShowApiKey ? "password" : "text")"
                                   @bind-Value="Config.ApiKey" class="form-control" />
                        <button type="button" class="toggle-btn" @onclick="ToggleApiKeyVisibility">
                            <span>@(ShowApiKey ? "👁" : "🔒")</span>
                        </button>
                    </div>
                    <ValidationMessage For="() => Config.ApiKey" />
                </div>

                <div class="form-group">
                    <label>Model *</label>
                    <InputText @bind-Value="Config.Model" class="form-control"
                               placeholder="gpt-3.5-turbo" />
                    <ValidationMessage For="() => Config.Model" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>前几页 *</label>
                        <InputNumber @bind-Value="Config.MaxPages" class="form-control" min="1" />
                    </div>
                    <div class="form-group">
                        <label>超时(秒) *</label>
                        <InputNumber @bind-Value="Config.RequestTimeout" class="form-control" min="1" />
                    </div>
                </div>

                <div class="form-group">
                    <label>处理间隔(毫秒) *</label>
                    <InputNumber @bind-Value="Config.ProcessInterval" class="form-control" min="0" />
                </div>

                <button type="submit" class="save-btn">保存配置</button>
            </EditForm>
        </div>

        <!-- 任务进度区 -->
        @if (Progress != null && Progress.Status != AnalysisStatus.NotStarted)
        {
            <div class="sidebar-section">
                <h4>任务进度</h4>
                <div class="progress-info">
                    <div class="progress-item">
                        <span>当前阶段：</span>
                        <span class="stage-text">@Progress.Stage.GetDisplayName()</span>
                    </div>
                    <div class="progress-item">
                        <span>页面进度：</span>
                        <span>@Progress.CurrentPage / @Progress.TotalPages</span>
                    </div>
                    <div class="progress-item">
                        <span>职位进度：</span>
                        <span>@Progress.ProcessedJobs / @Progress.TotalJobs</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Progress.LastMessage))
                    {
                        <div class="progress-message">@Progress.LastMessage</div>
                    }
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: @GetProgressPercent()%">
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- 结果展示区 -->
        @if (Progress?.Result != null)
        {
            <div class="sidebar-section">
                <h4>分析结果</h4>

                <!-- 技能关键词 -->
                <div class="result-section">
                    <h5>技能关键词</h5>
                    <div class="keywords-list">
                        @foreach (var keyword in Progress.Result.Keywords.Take(20))
                        {
                            <span class="keyword-tag">@keyword</span>
                        }
                        @if (Progress.Result.Keywords.Count > 20)
                        {
                            <span class="more-tag">...等 @Progress.Result.Keywords.Count 个</span>
                        }
                    </div>
                </div>

                <!-- 分类汇总 -->
                @if (Progress.Result.Categories.Any())
                {
                    <div class="result-section">
                        <h5>技能分类</h5>
                        @foreach (var category in Progress.Result.Categories)
                        {
                            <div class="category-group">
                                <strong>@category.Name</strong>
                                <div class="category-skills">
                                    @foreach (var skill in category.Skills)
                                    {
                                        <span class="skill-tag">@skill</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- 技能频次 -->
                @if (Progress.Result.Frequencies.Any())
                {
                    <div class="result-section">
                        <h5>技能频次</h5>
                        <div class="frequencies-list">
                            @foreach (var freq in Progress.Result.Frequencies.OrderByDescending(x => x.Value).Take(10))
                            {
                                <div class="frequency-item">
                                    <span class="freq-name">@freq.Key</span>
                                    <span class="freq-count">@freq.Value 次</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- 同义词归一 -->
                @if (Progress.Result.SynonymMappings.Any())
                {
                    <div class="result-section">
                        <h5>同义词归一</h5>
                        <div class="synonyms-list">
                            @foreach (var mapping in Progress.Result.SynonymMappings.Take(10))
                            {
                                <div class="synonym-item">
                                    <span class="original-word">@mapping.Key</span>
                                    <span class="arrow">→</span>
                                    <span class="standard-word">@mapping.Value</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- 总体总结 -->
                @if (!string.IsNullOrEmpty(Progress.Result.Summary))
                {
                    <div class="result-section">
                        <h5>总体总结</h5>
                        <p class="summary-text">@Progress.Result.Summary</p>
                    </div>
                }
            </div>
        }

        <!-- 导出区 -->
        @if (Progress?.Result != null)
        {
            <div class="sidebar-section">
                <button class="export-btn" @onclick="ExportJson">导出 JSON</button>
            </div>
        }

        <!-- 状态提示区 -->
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="sidebar-section">
                <div class="alert alert-error">@ErrorMessage</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <div class="sidebar-section">
                <div class="alert alert-success">@SuccessMessage</div>
            </div>
        }
    }
</div>

<style>
